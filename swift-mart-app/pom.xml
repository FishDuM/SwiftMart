<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>hk.ljx</groupId>
        <artifactId>swift-mart</artifactId>
        <version>${revision}</version>
    </parent>

    <groupId>hk.ljx.swiftmart.app</groupId>
    <artifactId>swift-mart-app</artifactId>
    <packaging>jar</packaging>

    <name>swift-mart-app</name>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <dependencies>
        <!-- 商品模块 -->
        <dependency>
            <groupId>hk.ljx.swiftmart.goods</groupId>
            <artifactId>swift-mart-goods</artifactId>
        </dependency>

        <!-- 订单模块 -->
        <dependency>
            <groupId>hk.ljx.swiftmart.order</groupId>
            <artifactId>swift-mart-order</artifactId>
        </dependency>

        <!-- 用户模块 -->
        <dependency>
            <groupId>hk.ljx.swiftmart.user</groupId>
            <artifactId>swift-mart-user</artifactId>
        </dependency>

        <!-- Spring Boot Web -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
            <exclusions>
                <exclusion>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-starter-logging</artifactId>
                </exclusion>
            </exclusions>
        </dependency>

        <!-- Spring Boot Test -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
            <exclusions>
                <exclusion>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-starter-logging</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
        </plugins>
    </build>
</project>
